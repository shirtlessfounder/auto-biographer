{
  "name": "auto-biographer",
  "version": "1.0.0",
  "description": "auto-biographer foundation for the semiautonomous X posting workflow.",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "cli": "tsx src/cli.ts",
    "tick": "tsx src/cli.ts tick",
    "draft-now": "tsx src/cli.ts draft-now",
    "migrate": "tsx src/db/migrate.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/pg": "^8.20.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
